# 🔒 Lockfile-Version stabil halten (npm 7+ verwendet v2 oder v3)
lockfile-version=3

# 🚫 Keine Änderungen am Lockfile bei "npm install"
# (npm 9+ führt nur Updates aus, wenn nötig)
package-lock=true

# ⚙️ Immer deterministische Builds
save-exact=true

# 🧱 Peer-Dependency-Auflösung stabilisieren
legacy-peer-deps=false

# 🔕 Weniger Rauschen bei Installationen
fund=false
audit=false
